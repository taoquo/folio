{
  "kind": "uml-class",
  "title": "Agent Session Model",
  "layout": "class-grid",
  "focus": "AgentSession",
  "types": [
    {
      "id": "AgentSession",
      "kind": "class",
      "name": "AgentSession",
      "x": 120,
      "y": 120,
      "attributes": ["id: UUID", "status: SessionStatus", "active_step: int"],
      "methods": ["advance() -> None", "append(result) -> None"]
    },
    {
      "id": "RunnableStep",
      "kind": "interface",
      "name": "RunnableStep",
      "x": 430,
      "y": 250,
      "attributes": ["kind: str"],
      "methods": ["run(ctx) -> StepResult"]
    },
    {
      "id": "MemoryStore",
      "kind": "class",
      "name": "MemoryStore",
      "x": 680,
      "y": 120,
      "attributes": ["namespace: str", "last_sync: datetime"],
      "methods": ["retrieve(query) -> list[Record]", "persist(batch) -> None"]
    },
    {
      "id": "PlanStep",
      "kind": "class",
      "name": "PlanStep",
      "x": 120,
      "y": 420,
      "attributes": ["prompt: PromptBlock", "tools: list[ToolCall]"],
      "methods": ["resolve(state) -> ToolCall"]
    },
    {
      "id": "ToolCall",
      "kind": "class",
      "name": "ToolCall",
      "x": 430,
      "y": 420,
      "attributes": ["tool_name: str", "arguments: dict[str, Any]"],
      "methods": ["execute() -> ToolResult"]
    },
    {
      "id": "SessionStatus",
      "kind": "enum",
      "name": "SessionStatus",
      "x": 680,
      "y": 420,
      "attributes": ["QUEUED", "RUNNING", "WAITING_TOOL", "COMPLETED"],
      "methods": []
    }
  ],
  "relationships": [
    {
      "source": "AgentSession",
      "target": "PlanStep",
      "kind": "composition",
      "target_multiplicity": "*"
    },
    {
      "source": "PlanStep",
      "target": "RunnableStep",
      "kind": "inheritance"
    },
    {
      "source": "AgentSession",
      "target": "MemoryStore",
      "kind": "association",
      "label": "retrieves",
      "route_policy": "top-lane",
      "label_lane": "top",
      "label_offset": -10
    },
    {
      "source": "PlanStep",
      "target": "ToolCall",
      "kind": "aggregation",
      "target_multiplicity": "*"
    }
  ]
}
